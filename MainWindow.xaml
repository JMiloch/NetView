<Window x:Class="NetView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NetView"
        Title="NetView"
        Height="900" Width="1400" MinWidth="900" MinHeight="700"
        Background="#FFFFFF"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:BoolToPortBrushConverter x:Key="PortBrushConv"/>
        <local:BoolToPortBorderConverter x:Key="PortBorderConv"/>
        <local:BoolToPortTextConverter x:Key="PortTextConv"/>
        <local:PortTypeConverter x:Key="PortTypeConv"/>
        <local:PortTypeBadgeBgConverter x:Key="PortTypeBadgeBgConv"/>
        <local:PortTypeBadgeFgConverter x:Key="PortTypeBadgeFgConv"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisConv"/>
        <local:PortMarginTopConverter x:Key="PortMarginTopConv"/>
        <local:PortMarginBottomConverter x:Key="PortMarginBottomConv"/>

        <SolidColorBrush x:Key="BgPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgCard" Color="#F5F4F0"/>
        <SolidColorBrush x:Key="TxtHeading" Color="#1A1A18"/>
        <SolidColorBrush x:Key="TxtBody" Color="#1A1A18"/>
        <SolidColorBrush x:Key="TxtSub" Color="#9C9A92"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#185FA5"/>
        <SolidColorBrush x:Key="BorderLight" Color="#D0CFC8"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TxtSub}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Styled tooltip -->
        <Style x:Key="PortToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#F5F4F0"/>
            <Setter Property="BorderBrush" Value="#D0CFC8"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="12,10,12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="{StaticResource BgPrimary}">
        <StackPanel Margin="32,28,32,28" MaxWidth="1300">

            <!-- Title -->
            <TextBlock Text="NetView"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TxtHeading}" Margin="0,0,0,4"/>
            <TextBlock Text="Switch Port Manager  ·  USW Pro Max 48  ·  Click to configure"
                       FontSize="12" Foreground="{StaticResource TxtSub}" Margin="0,0,0,28"/>

            <!-- ═══════ SWITCH INFO ═══════ -->
            <TextBlock Text="SWITCH" Style="{StaticResource SectionHeader}"/>

            <Border Background="{StaticResource BgCard}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0.5"
                    Padding="14,10,14,10" Margin="0,0,0,28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SWITCH NAME" FontSize="10" FontWeight="Medium"
                                   Foreground="{StaticResource TxtSub}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SwitchName, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" FontSize="14" FontWeight="Medium"
                                 Foreground="{StaticResource TxtHeading}"
                                 Background="Transparent" BorderThickness="0" Padding="0,2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="LOCATION" FontSize="10" FontWeight="Medium"
                                   Foreground="{StaticResource TxtSub}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" FontSize="14"
                                 Foreground="{StaticResource TxtHeading}"
                                 Background="Transparent" BorderThickness="0" Padding="0,2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                   Foreground="{StaticResource TxtSub}" HorizontalAlignment="Right"/>
                        <Button Content="CSV Export" Click="ExportCsv_Click" Margin="0,6,0,0"
                                Padding="10,4" Cursor="Hand" HorizontalAlignment="Right">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6" BorderThickness="0.5"
                                            BorderBrush="{StaticResource BorderLight}"
                                            Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#F5F4F0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════ SWITCH VISUAL ═══════ -->
            <TextBlock Text="PORT MAP" Style="{StaticResource SectionHeader}"/>

            <!-- Switch body -->
            <Border Background="#E8E7E3" CornerRadius="10"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="1"
                    Padding="16,14,16,14">
                <StackPanel>
                    <!-- Top row: odd ports -->
                    <ItemsControl ItemsSource="{Binding TopRow}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="42" Height="38"
                                        Margin="{Binding PortNumber, Converter={StaticResource PortMarginTopConv}}"
                                        CornerRadius="3,3,0,0"
                                        Background="{Binding IsConfigured, Converter={StaticResource PortBrushConv}}"
                                        BorderBrush="{Binding IsConfigured, Converter={StaticResource PortBorderConv}}"
                                        BorderThickness="0.5"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="Port_Click"
                                        Tag="{Binding}">
                                    <Border.ToolTip>
                                        <ToolTip Style="{StaticResource PortToolTip}">
                                            <StackPanel MinWidth="180">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock FontWeight="SemiBold" FontSize="13"
                                                               Foreground="#1A1A18">
                                                        <Run Text="Port "/><Run Text="{Binding PortNumber, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <Border Background="{Binding PortNumber, Converter={StaticResource PortTypeBadgeBgConv}}"
                                                            CornerRadius="6" Padding="6,1" Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding PortNumber, Converter={StaticResource PortTypeConv}}"
                                                                   FontSize="9" FontWeight="Medium"
                                                                   Foreground="{Binding PortNumber, Converter={StaticResource PortTypeBadgeFgConv}}"/>
                                                    </Border>
                                                </StackPanel>
                                                <Border BorderBrush="#D0CFC8" BorderThickness="0,0.5,0,0"
                                                        Margin="0,6,0,0" Padding="0,6,0,0"
                                                        Visibility="{Binding IsConfigured, Converter={StaticResource BoolToVisConv}}">
                                                    <StackPanel>
                                                        <TextBlock FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#1A1A18" Text="{Binding DeviceName}"/>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   Foreground="#9C9A92" Text="{Binding IpAddress}"
                                                                   Margin="0,2,0,0"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock FontSize="10" FontWeight="Medium" Foreground="#9C9A92"
                                                                       Text="VLAN "/>
                                                            <TextBlock FontFamily="Consolas" FontSize="10"
                                                                       Foreground="#1A1A18" Text="{Binding Vlan}"/>
                                                        </StackPanel>
                                                        <TextBlock FontSize="10" Foreground="#9C9A92"
                                                                   Text="{Binding Function}" Margin="0,3,0,0"
                                                                   TextWrapping="Wrap" MaxWidth="220"
                                                                   FontStyle="Italic"/>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="Not configured" FontSize="10" Foreground="#9C9A92"
                                                           FontStyle="Italic" Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="{Binding PortNumber}"
                                               FontFamily="Consolas" FontSize="10" FontWeight="Medium"
                                               Foreground="{Binding IsConfigured, Converter={StaticResource PortTextConv}}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bottom row: even ports -->
                    <ItemsControl ItemsSource="{Binding BottomRow}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="42" Height="38"
                                        Margin="{Binding PortNumber, Converter={StaticResource PortMarginBottomConv}}"
                                        CornerRadius="0,0,3,3"
                                        Background="{Binding IsConfigured, Converter={StaticResource PortBrushConv}}"
                                        BorderBrush="{Binding IsConfigured, Converter={StaticResource PortBorderConv}}"
                                        BorderThickness="0.5"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="Port_Click"
                                        Tag="{Binding}">
                                    <Border.ToolTip>
                                        <ToolTip Style="{StaticResource PortToolTip}">
                                            <StackPanel MinWidth="180">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock FontWeight="SemiBold" FontSize="13"
                                                               Foreground="#1A1A18">
                                                        <Run Text="Port "/><Run Text="{Binding PortNumber, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <Border Background="{Binding PortNumber, Converter={StaticResource PortTypeBadgeBgConv}}"
                                                            CornerRadius="6" Padding="6,1" Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding PortNumber, Converter={StaticResource PortTypeConv}}"
                                                                   FontSize="9" FontWeight="Medium"
                                                                   Foreground="{Binding PortNumber, Converter={StaticResource PortTypeBadgeFgConv}}"/>
                                                    </Border>
                                                </StackPanel>
                                                <Border BorderBrush="#D0CFC8" BorderThickness="0,0.5,0,0"
                                                        Margin="0,6,0,0" Padding="0,6,0,0"
                                                        Visibility="{Binding IsConfigured, Converter={StaticResource BoolToVisConv}}">
                                                    <StackPanel>
                                                        <TextBlock FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#1A1A18" Text="{Binding DeviceName}"/>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   Foreground="#9C9A92" Text="{Binding IpAddress}"
                                                                   Margin="0,2,0,0"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock FontSize="10" FontWeight="Medium" Foreground="#9C9A92"
                                                                       Text="VLAN "/>
                                                            <TextBlock FontFamily="Consolas" FontSize="10"
                                                                       Foreground="#1A1A18" Text="{Binding Vlan}"/>
                                                        </StackPanel>
                                                        <TextBlock FontSize="10" Foreground="#9C9A92"
                                                                   Text="{Binding Function}" Margin="0,3,0,0"
                                                                   TextWrapping="Wrap" MaxWidth="220"
                                                                   FontStyle="Italic"/>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="Not configured" FontSize="10" Foreground="#9C9A92"
                                                           FontStyle="Italic" Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="{Binding PortNumber}"
                                               FontFamily="Consolas" FontSize="10" FontWeight="Medium"
                                               Foreground="{Binding IsConfigured, Converter={StaticResource PortTextConv}}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Legend -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Border Width="10" Height="10" CornerRadius="3"
                        Background="#EAF3DE" BorderBrush="#3B6D11" BorderThickness="0.5"
                        Margin="0,0,5,0"/>
                <TextBlock Text="Configured" FontSize="11"
                           Foreground="{StaticResource TxtBody}" Margin="0,0,16,0"/>
                <Border Width="10" Height="10" CornerRadius="3"
                        Background="#F5F4F0" Margin="0,0,5,0"/>
                <TextBlock Text="Not configured" FontSize="11"
                           Foreground="{StaticResource TxtBody}" Margin="0,0,24,0"/>

                <Border Width="10" Height="10" CornerRadius="3"
                        Background="#F5F4F0" Margin="0,0,5,0"/>
                <TextBlock Text="1 GbE (1-32)" FontSize="11"
                           Foreground="{StaticResource TxtSub}" Margin="0,0,12,0"/>
                <Border Width="10" Height="10" CornerRadius="3"
                        Background="#FAEEDA" Margin="0,0,5,0"/>
                <TextBlock Text="2.5 GbE (33-48)" FontSize="11"
                           Foreground="{StaticResource TxtSub}" Margin="0,0,12,0"/>
                <Border Width="10" Height="10" CornerRadius="3"
                        Background="#E6F1FB" Margin="0,0,5,0"/>
                <TextBlock Text="SFP+ 10G (49-52)" FontSize="11"
                           Foreground="{StaticResource TxtSub}"/>
            </StackPanel>

            <!-- ═══════ PORT TABLE ═══════ -->
            <TextBlock Text="PORT OVERVIEW — CONFIGURED PORTS" Style="{StaticResource SectionHeader}"
                       Margin="0,28,0,10"/>

            <!-- Table header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.6*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="6" BorderBrush="{StaticResource BorderLight}"
                        BorderThickness="0,0,0,0.5"/>
                <TextBlock Grid.Column="0" Text="PORT" FontSize="10" FontWeight="Medium"
                           Foreground="{StaticResource TxtSub}" Padding="8,4,8,8"/>
                <TextBlock Grid.Column="1" Text="TYPE" FontSize="10" FontWeight="Medium"
                           Foreground="{StaticResource TxtSub}" Padding="8,4,8,8"/>
                <TextBlock Grid.Column="2" Text="DEVICE" FontSize="10" FontWeight="Medium"
                           Foreground="{StaticResource TxtSub}" Padding="8,4,8,8"/>
                <TextBlock Grid.Column="3" Text="IP" FontSize="10" FontWeight="Medium"
                           Foreground="{StaticResource TxtSub}" Padding="8,4,8,8"/>
                <TextBlock Grid.Column="4" Text="VLAN" FontSize="10" FontWeight="Medium"
                           Foreground="{StaticResource TxtSub}" Padding="8,4,8,8"/>
                <TextBlock Grid.Column="5" Text="FUNCTION" FontSize="10" FontWeight="Medium"
                           Foreground="{StaticResource TxtSub}" Padding="8,4,8,8"/>
            </Grid>

            <!-- Table rows -->
            <ItemsControl x:Name="PortTable">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,0.5"
                                Cursor="Hand" MouseLeftButtonDown="Port_Click" Tag="{Binding}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F4F0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.5*"/>
                                    <ColumnDefinition Width="0.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding PortNumber}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TxtBody}"
                                           Padding="8,7" VerticalAlignment="Center"/>

                                <Border Grid.Column="1" Padding="8,5" VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                    <Border Background="{Binding PortNumber, Converter={StaticResource PortTypeBadgeBgConv}}"
                                            CornerRadius="8" Padding="6,2">
                                        <TextBlock Text="{Binding PortNumber, Converter={StaticResource PortTypeConv}}"
                                                   FontSize="9"
                                                   Foreground="{Binding PortNumber, Converter={StaticResource PortTypeBadgeFgConv}}"/>
                                    </Border>
                                </Border>

                                <TextBlock Grid.Column="2" Text="{Binding DeviceName}"
                                           FontFamily="Consolas" FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource TxtBody}"
                                           Padding="8,7" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="3" Text="{Binding IpAddress}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TxtSub}"
                                           Padding="8,7" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4" Text="{Binding Vlan}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TxtSub}"
                                           Padding="8,7" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="5" Text="{Binding Function}"
                                           FontSize="11" Foreground="{StaticResource TxtSub}"
                                           Padding="8,7" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyStateText"
                       Text="No ports configured yet — Click a port on the switch above"
                       FontSize="12" Foreground="{StaticResource TxtSub}"
                       HorizontalAlignment="Center" Margin="0,20,0,0"/>

            <!-- Footer -->
            <Border BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0.5,0,0"
                    Margin="0,36,0,0" Padding="0,14,0,0">
                <DockPanel>
                    <TextBlock Text="USW Pro Max 48 · 32×1G · 16×2.5G · 4×SFP+ 10G"
                               FontSize="11" Foreground="{StaticResource TxtSub}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TxtSub}"
                               HorizontalAlignment="Right" DockPanel.Dock="Right"
                               Text="Miloch · NetView · 1.0.26.3"/>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
