<Window x:Class="NetView.PortEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NetView"
        Title="Configure Port"
        Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        ShowInTaskbar="False">

    <Window.Resources>
        <local:PortTypeConverter x:Key="PortTypeConv"/>
        <local:PortTypeBadgeBgConverter x:Key="PortTypeBadgeBgConv"/>
        <local:PortTypeBadgeFgConverter x:Key="PortTypeBadgeFgConv"/>

        <SolidColorBrush x:Key="BgCard" Color="#F5F4F0"/>
        <SolidColorBrush x:Key="TxtHeading" Color="#1A1A18"/>
        <SolidColorBrush x:Key="TxtSub" Color="#9C9A92"/>
        <SolidColorBrush x:Key="BorderLight" Color="#D0CFC8"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#185FA5"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TxtSub}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TxtHeading}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24,20,24,20">

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TxtHeading}" VerticalAlignment="Center"/>
            <Border x:Name="TypeBadge" CornerRadius="8" Padding="8,2" Margin="10,0,0,0"
                    VerticalAlignment="Center">
                <TextBlock x:Name="TypeText" FontSize="9" FontWeight="Medium"/>
            </Border>
        </StackPanel>

        <!-- Fields -->
        <TextBlock Text="DEVICE NAME" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TxtDeviceName" Style="{StaticResource FieldInput}"/>

        <TextBlock Text="IP ADDRESS" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TxtIpAddress" Style="{StaticResource FieldInput}"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="VLAN" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtVlan" Style="{StaticResource FieldInput}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="FUNCTION / PURPOSE" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFunction" Style="{StaticResource FieldInput}"/>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Clear" Click="ClearClick" Margin="0,0,8,0"
                    Padding="12,5" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" BorderThickness="0.5"
                                BorderBrush="{StaticResource BorderLight}"
                                Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F4F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" IsCancel="True" Padding="12,5" Cursor="Hand"
                    Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" BorderThickness="0.5"
                                BorderBrush="{StaticResource BorderLight}"
                                Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F4F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Save" Click="SaveClick" IsDefault="True"
                    Padding="12,5" Cursor="Hand" FontWeight="Medium">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{StaticResource AccentBlue}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A4D6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="White"/>
                </Button.Foreground>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
